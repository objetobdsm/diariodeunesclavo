/* ==========================================================
   diario de un esclavo · segunda edición
   ========================================================== */

:root{
  --bg:#11151b;
  --text:#e8e3d8;
  --muted:#9ea7b3;
  --link:#d6c39a;
  --link-hover:#efe0bc;
  --border:#2b3440;
  --max-width:760px;
}

*{
  box-sizing:border-box;
}

html{
  font-size:19px;
}

body{
  margin:0;
  background:var(--bg);
  color:var(--text);
  font-family:Georgia,"Times New Roman",serif;
  line-height:1.9;
}

.container{
  width:min(92%, var(--max-width));
  margin:0 auto;
}

.site-header{
  padding:4.5rem 0 3rem;
}

.site-title{
  margin:0;
  font-size:3rem;
  font-weight:400;
  letter-spacing:-0.02em;
}

.site-title a{
  color:var(--text);
  text-decoration:none;
}

.site-description{
  margin-top:1rem;
  color:var(--muted);
  font-size:1.05rem;
}

.main-nav{
  margin-top:3rem;
  padding-top:1.5rem;
  border-top:1px solid var(--border);
}

.main-nav ul{
  list-style:none;
  margin:0;
  padding:0;
  display:flex;
  flex-wrap:wrap;
  gap:1.4rem 2.2rem;
}

.main-nav a{
  color:var(--muted);
  text-decoration:none;
}

.main-nav a:hover{
  color:var(--link);
}

.content{
  padding:1rem 0 5rem;
}

section{
  margin-bottom:5rem;
}

h1{
  font-size:2.2rem;
  font-weight:400;
}

h2{
  font-size:1.3rem;
  font-weight:400;
  color:var(--muted);
  margin-bottom:2rem;
}

h3{
  font-size:1.45rem;
  font-weight:400;
  margin-bottom:.5rem;
}

.post-list{
  list-style:none;
  padding:0;
  margin:0;
}

.post-list li{
  margin-bottom:3rem;
}

.post-date{
  color:var(--muted);
  font-size:.9rem;
}

a{
  color:var(--link);
}

a:hover{
  color:var(--link-hover);
}

.intro{
  font-size:1.35rem;
  line-height:2;
  margin-bottom:2rem;
}

.start-link{
  margin-top:2rem;
}

.site-footer{
  margin-top:5rem;
  padding:2rem 0;
  border-top:1px solid var(--border);
  color:var(--muted);
  font-size:.9rem;
}